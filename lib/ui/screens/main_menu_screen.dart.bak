  IconData _getIconForLabel(String label) {
                    _buildMenuButton(
                      context,
                      'ACHIEVEMENTS',
                      const Color(0xFFFFD700),
                      () => _navigateToAchievements(context),
                    ),
    switch (label) {
                    _buildMenuButton(
                      context,
                      'ACHIEVEMENTS',
                      const Color(0xFFFFD700),
                      () => _navigateToAchievements(context),
                    ),
      case 'NEW RUN': 
                    _buildMenuButton(
                      context,
                      'ACHIEVEMENTS',
                      const Color(0xFFFFD700),
                      () => _navigateToAchievements(context),
                    ),
      case 'CONTINUE':
                    _buildMenuButton(
                      context,
                      'ACHIEVEMENTS',
                      const Color(0xFFFFD700),
                      () => _navigateToAchievements(context),
                    ),
        return Icons.play_arrow;
                    _buildMenuButton(
                      context,
                      'ACHIEVEMENTS',
                      const Color(0xFFFFD700),
                      () => _navigateToAchievements(context),
                    ),
      case 'LOAD GAME': 
                    _buildMenuButton(
                      context,
                      'ACHIEVEMENTS',
                      const Color(0xFFFFD700),
                      () => _navigateToAchievements(context),
                    ),
        return Icons.folder_open;
                    _buildMenuButton(
